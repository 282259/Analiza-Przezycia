\section{Lista 1}

\subsection{Deklaracje funkcji}

Dla rozkładu wykładniczego Weibulla ${\cal EW}\left(\alpha, \beta, \gamma\right)$ definiujemy funkcję gęstości $f$, dystrybuantę $F$, odwrotną dytrybuantę $Q$ oraz funkcję hazardu $h$ zgodnie z poniższymi wzorami

\begin{equation*}
f(t;\alpha,\beta,\gamma) = 
\frac{\alpha \gamma}{\beta}
\left( \frac{t}{\beta} \right)^{\alpha - 1}
\left\{ 1 - \exp\!\left[ -\left( \frac{t}{\beta} \right)^{\alpha} \right] \right\}^{\gamma - 1}
\exp\!\left[ -\left( \frac{t}{\beta} \right)^{\alpha} \right]
\mathbf{1}_{(0,\infty)}(t)
\end{equation*}

\begin{equation*}
F(t;\alpha,\beta,\gamma) = \left\{ 1 - \exp\!\left[ - \left( \frac{t}{\beta} \right)^{\alpha} \right]\right\}^{\gamma}
\end{equation*}

\begin{equation*}
Q(p;\alpha,\beta,\gamma) = \beta \left[ - \ln\!\left(1 - p^{\frac{1}{\gamma}} \right) \right]^{\frac{1}{\alpha}}
\end{equation*}

\begin{equation*}
h(t) = \frac{f(t)}{1 - F(t)}
\end{equation*}


<<funkcje, echo=FALSE, warning=FALSE, message=FALSE>>=
#Zadanie 1
gestosc <- function(t, alfa, beta, gamma){
    return((alfa*gamma/beta) * ((t/beta)^(alfa-1)) * (1 - exp(-(t/beta)^(alfa)))^(gamma -1) * exp(-(t/beta)^(alfa)))
  }

dystrybuanta <- function(t, alfa, beta, gamma) {
  (1 - exp(-(t / beta)^alfa))^gamma
}

odwrotna.dystrybuanta <- function(p, alfa, beta, gamma){
  return(beta * (-log(1-p^(1/gamma)))^(1/alfa))
}
hazard <- function(t, alfa, beta, gamma) {
  f <- gestosc(t, alfa, beta, gamma)
  F <- dystrybuanta(t, alfa, beta, gamma)
  return(f / (1 - F))
}
@


\subsection{Wykresy funkcji hazardu}
W celu zilustrowania kształtu funkcji hazaru wykorzystano następujące parametry

\label{tab:parametryHazard}
\begin{table}[H]
\centering
\caption{Zestawy parametrów wykorzystane do ilustracji kształtu funkcji hazardu}
\begin{tabular}{cccc}
\toprule
$\alpha$ & $\beta$ & $\gamma$\\
\midrule
0.5 & 2 & 0.75\\
0.75 & 1 & 2\\
1 & 2 & 1\\
1.5 & 3 & 3\\
1.5 & 4 & 0.125\\
\bottomrule
\end{tabular}
\end{table}

Kształty tych funkcji przedstawiamy na rysunku \ref{fig:wykresHazardu}

\begin{figure}[H]
<<wykres_hazardu, echo=FALSE, warning=FALSE, message=FALSE>>=
#Zadanie 2
t <- seq(0.001, 10, length.out = 400)

ggplot() +
  geom_line(aes(x = t, y = hazard(t, 1, 2, 1), color = "1, 2, 1"),  size = 1.2) +
  geom_line(aes(x = t, y = hazard(t, 0.5, 2, 0.75), color = "0.5, 2, 0.75"), size = 1.2) +
  geom_line(aes(x = t, y = hazard(t, 1.5, 3, 3), color = "1.5, 3, 3"), size = 1.2) + 
  geom_line(aes(x = t, y = hazard(t, 0.75, 1, 2), color = "0.75, 1, 2"), size = 1.2) +
  geom_line(aes(x = t, y = hazard(t, 1.5, 4, 0.125), color = "1.5, 4, 0.125"), size = 1.2) +
  scale_color_manual(
    name = "",
    values = c(
      "1, 2, 1" = "skyblue",
      "0.5, 2, 0.75" = "pink",
      "1.5, 3, 3"= "lightgreen",
      "0.75, 1, 2" = "lavender",
      "1.5, 4, 0.125" = "peachpuff"
    )
  ) +
  labs(
    x = "t",
    y = "h(t)"
  ) +
  theme_minimal(base_size = 13) +
  theme(
    plot.title = element_text(hjust = 0.5, face = "bold"),
    legend.position = "bottom",
    legend.text = element_text(size = 8.25)
  ) +
  coord_cartesian(ylim = c(0, 1.5))


@
\caption{Wykres funkcji hazardu w zależności od parametrów $\alpha$, $\beta$, $\gamma$}
\label{fig:wykresHazardu}
\end{figure}

Zauważamy, że kształt wykresu funkcji hazardu zależy od parametrów w następujący sposób
\begin{itemize}
  \item Dla $\alpha \leqslant 1$ oraz $\alpha\gamma \leqslant 1$ funkcja jest malejąca
  \item Dla $\alpha < 1$ oraz $\alpha\gamma > 1$ funkcja jest jednomodalna
  \item Dla $\alpha = \gamma = 1$ funkcja jest stała
  \item Dla $\alpha \geqslant 1$ oraz $\alpha\gamma \geqslant 1$ funkcja jest rosnąca
  \item Dla $\alpha > 1$ oraz $\alpha\gamma < 1$ funkcja jest wannowa
\end{itemize}

\subsection{Funkcja do generowania zmiennych rozkładu $\cal EW$}

W celu wygenerowania danych rozkładu $\mathcal{EW}$ korzystamy z metody odwrotnej dystrybuanty. Najpierw, przy użyciu funkcji $runif$, generujemy wartości zmiennej losowej o rozkładzie jednostajnym $\mathcal{U}(0,1)$. Następnie wygenerowane wartości przekształcamy przez odwrotność dystrybuanty rozkładu wykładniczego Weibulla, zgodnie ze wzorem podanym w deklaracji powyżej, tym samym otrzymujemy próbkę o rozkładzie $\mathcal{EW}$ o zadanych parametrach $\alpha$, $\beta$ i $\gamma$.

<<GenDanych, echo=TRUE, warning=FALSE, message=FALSE>>=
#Funkcja do generowania danych z zadanego rozkładu 
#korzystamy z metody odwrotnej dystrybuanty
generowanie <- function(t, alfa, beta, gamma){
  u <- runif(t) #U(0,1)
  odwrotna.dystrybuanta(u,alfa, beta, gamma)
}
@

\subsection{Histogramy z funkcją gęstości w oparciu o wygenerowane dane}

Na rysunku \ref{fig:wykresyGestosci} przedstawione są wykresy gęstości rozkładu oraz histogramy dla następujących trójek parametrów

\begin{itemize}
 \item $\alpha_{1} = 1.5$, $\beta_{1} = 3$, $\gamma_{1} = 3$
 \item $\alpha_{2} = 1$, $\beta_{2} = 1$, $\gamma_{2} = 2$
\end{itemize}

Dla każdego zestawu parametrów generujemy wykresy dla dwóch różnych liczebności zbiorów - $n = 50$ oraz $n = 100$

\begin{figure}[H]
<<echo=FALSE, warning=FALSE, message=FALSE>>=
#Zadanie 4
x1<- generowanie(50, 1.5, 3, 3)
x2<- generowanie(100, 1.5, 3, 3)

k1<- generowanie(50, 1, 1, 2)
k2<- generowanie(100, 1, 1, 2)
t <- seq(0.001, 10, length.out = 400)

# EW(1.5, 3, 3), n=50
p1<- ggplot() +
  geom_histogram(aes(x = x1, y = ..density..), bins = 15, fill = "lightpink", color = "white") +
  geom_line(aes(x = t, y = gestosc(t, 1.5, 3, 3)), color = "skyblue", size = 1.2) +
  labs(title = "1.5, 3, 3, 50", x = "x", y = "Gęstość") +
  theme_minimal()+
  coord_cartesian(xlim = c(0, 8), ylim = c(0, 0.4))

# EW(1.5, 3, 3), n=100
p2<-ggplot() +
  geom_histogram(aes(x = x2, y = ..density..), bins = 20, fill = "lightpink", color = "white") +
  geom_line(aes(x = t, y = gestosc(t, 1.5, 3, 3)), color = "skyblue", size = 1.2) +
  labs(title = "1.5, 3, 3, 100", x = "x", y = "Gęstość") +
  theme_minimal()+
  coord_cartesian(xlim = c(0, 10), ylim = c(0, 0.5))

# EW(1,1,2), n=50
p3<- ggplot() +
  geom_histogram(aes(x = k1, y = ..density..), bins = 15, fill = "lightpink", color = "white") +
  geom_line(aes(x = t, y = gestosc(t, 1, 1, 2)), color = "skyblue", size = 1.2) +
  labs(title = "1, 1, 2, 50", x = "x", y = "Gęstość") +
  theme_minimal()

# EW(1,1,2), n=100
p4<- ggplot() +
  geom_histogram(aes(x = k2, y = ..density..), bins = 20, fill = "lightpink", color = "white") +
  geom_line(aes(x = t, y = gestosc(t, 1, 1, 2)), color = "skyblue", size = 1.2) +
